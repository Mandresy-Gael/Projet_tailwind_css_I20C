  <script>

    /* -------------------------------------------------------
       1. MENU BURGER : ouvre et ferme le menu mobile
          en animant les 3 lignes en croix
    ------------------------------------------------------- */
    var boutonBurger = document.getElementById('btn-burger');
    var menuMobile   = document.getElementById('menu-mobile');
    var ligne1       = document.getElementById('ligne1');
    var ligne2       = document.getElementById('ligne2');
    var ligne3       = document.getElementById('ligne3');
    var estOuvert    = false;

    boutonBurger.addEventListener('click', function () {
      if (!estOuvert) {
        menuMobile.classList.remove('hidden');
        ligne1.style.transform = 'rotate(45deg) translate(5px, 5px)';
        ligne2.style.opacity   = '0';
        ligne3.style.transform = 'rotate(-45deg) translate(5px, -5px)';
        estOuvert = true;
      } else {
        menuMobile.classList.add('hidden');
        ligne1.style.transform = '';
        ligne2.style.opacity   = '1';
        ligne3.style.transform = '';
        estOuvert = false;
      }
    });


    /* -------------------------------------------------------
       2. SOUS-MENU LUNETTES (mobile)
          clique → affiche ou cache les 3 sous-liens
    ------------------------------------------------------- */
    var boutonLunettes   = document.getElementById('btn-lunettes-mobile');
    var sousMenuLunettes = document.getElementById('sous-menu-lunettes');
    var fleche           = document.getElementById('fleche-lunettes');
    var sousMenuOuvert   = false;

    boutonLunettes.addEventListener('click', function () {
      if (!sousMenuOuvert) {
        sousMenuLunettes.classList.remove('hidden');
        sousMenuLunettes.classList.add('flex');
        fleche.style.transform = 'rotate(180deg)';
        sousMenuOuvert = true;
      } else {
        sousMenuLunettes.classList.add('hidden');
        sousMenuLunettes.classList.remove('flex');
        fleche.style.transform = '';
        sousMenuOuvert = false;
      }
    });


    /* -------------------------------------------------------
       3. CARROUSEL HERO
          défilement automatique toutes les 5 secondes
          avec flèches et points de navigation
    ------------------------------------------------------- */
    var carrouselHero = new Swiper('#swiper-hero', {
      loop: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false
      },
      speed: 800,
      pagination: {
        el: '.swiper-pagination',
        clickable: true
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev'
      }
    });


    /* -------------------------------------------------------
       4. CARROUSEL MARQUES
          affiche plusieurs logos à la fois,
          défilement automatique continu
    ------------------------------------------------------- */
    var carrouselMarques = new Swiper('#swiper-marques', {
      loop: true,
      autoplay: {
        delay: 2500,
        disableOnInteraction: false
      },
      speed: 600,
      slidesPerView: 3,
      spaceBetween: 30,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev'
      },
      breakpoints: {
        640:  { slidesPerView: 4, spaceBetween: 30 },
        1024: { slidesPerView: 6, spaceBetween: 40 }
      }
    });

  </script>

